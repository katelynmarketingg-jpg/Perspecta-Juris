# ─────────────────────────────────────────────────────────────
#  Perspecta Juris — variáveis de ambiente do SERVIDOR
#  NUNCA comite o .env real. Segredos ficam só no servidor.
# ─────────────────────────────────────────────────────────────

# Server
PORT=8788
HOST=0.0.0.0
NODE_ENV=development            # em produção use: production

# ── Banco de dados (Postgres gerenciado) ─────────────────────
# Supabase (recomendado): Project Settings → Database → Connection string → "URI".
#   Use o "Connection pooler" (porta 6543) para apps em escala.
# Ex.: postgresql://postgres.xxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
# (Neon também funciona — é o mesmo padrão postgresql://)
DATABASE_URL=postgresql://postgres.xxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# ── JWT (autenticação) ───────────────────────────────────────
# Gere um segredo forte:  openssl rand -base64 48
# Em produção o servidor NÃO sobe com segredo padrão/curto (fail-fast).
JWT_SECRET=troque-por-openssl-rand-base64-48
JWT_EXPIRES_IN=2h
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Administrador (master) — criado pelo seed ────────────────
# Seu acesso separado de administradora. Em produção, defina uma senha forte.
MASTER_LOGIN=katelyn
MASTER_EMAIL=
MASTER_PASSWORD=                 # ≥8 caracteres — obrigatório em produção

# ── CORS ─────────────────────────────────────────────────────
# Domínio do frontend em produção (ex.: https://app.perspectajuris.com.br)
CLIENT_ORIGIN=

# ── Arquivos ─────────────────────────────────────────────────
DATA_DIR=./data
FILES_DIR=./data/files

# ── Perspecta Hub (CRM) — link cruzado / SSO ─────────────────
HUB_URL=https://perspecta-hub.onrender.com

# ── Asaas (pagamentos por link / Pix / boleto) — opcional ────
# Painel Asaas → Integrações → Chave de API. FICA SÓ NO SERVIDOR.
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox        # sandbox | production
ASAAS_WEBHOOK_TOKEN=             # token que valida os webhooks recebidos

# ── Z-API WhatsApp — opcional ────────────────────────────────
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
