# Server
PORT=8788
HOST=0.0.0.0
NODE_ENV=development

# PostgreSQL (Neon.tech)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/perspecta_juris?sslmode=require

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=2h
REFRESH_TOKEN_EXPIRES_IN=7d

# Files
DATA_DIR=./data
FILES_DIR=./data/files

# Hub URL (link cruzado)
HUB_URL=https://perspecta-hub.onrender.com

# Asaas (pagamentos) - opcional
ASAAS_API_KEY=
